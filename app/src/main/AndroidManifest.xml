<!-- ============================================================================
     📅 更新日期：2026-03-23
     🔧 更新内容：
       - 添加通知权限（Android 13+）
       - 添加核心模块所需权限
     📝 说明：应用清单 - 权限和服务配置（重构版）
     ============================================================================ -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 基础网络权限 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- 前台服务权限（Android 14+ 需要 specialUse） -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    
    <!-- ✅ 新增：通知权限（Android 13+ 必需） -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- 系统弹窗权限（悬浮窗） -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    
    <!-- 防止休眠（抢票时保持 CPU 运行） -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    
    <!-- 开机自启（可选） -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    
    <!-- ✅ 新增：振动权限（用于通知） -->
    <uses-permission android:name="android.permission.VIBRATE" />
    
    <!-- ✅ 新增：绕过勿扰模式（用于紧急通知） -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <queries>
        <package android:name="com.taobao.taobao" />
        <package android:name="cn.damai" />
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.DamaiTicketHelper"
        tools:targetApi="31">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.DamaiTicketHelper">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.TaskConfigActivity"
            android:exported="false"
            android:label="配置任务"
            android:parentActivityName=".ui.MainActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".ui.MainActivity" />
        </activity>

        <!-- 🆕 观众管理界面 -->
        <activity
            android:name=".ui.AudienceManagerActivity"
            android:exported="false"
            android:label="观众管理"
            android:parentActivityName=".ui.MainActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".ui.MainActivity" />
        </activity>

        <!-- 🆕 智能抢票界面 -->
        <activity
            android:name=".ui.SmartGrabActivity"
            android:exported="false"
            android:label="智能抢票"
            android:parentActivityName=".ui.MainActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".ui.MainActivity" />
        </activity>

        <!-- 无障碍服务 -->
        <service
            android:name=".service.TicketGrabbingAccessibilityService"
            android:enabled="true"
            android:exported="true"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- 前台服务 -->
        <service
            android:name=".service.TicketGrabbingForegroundService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

        <!-- ✅ 新增：核心服务声明（后续集成使用） -->
        <service
            android:name=".core.CoreService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

    </application>

</manifest>
